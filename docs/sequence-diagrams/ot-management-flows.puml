@startuml OT Management - Create Plan Flow
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title OT Management - Create Plan Flow

actor Leader
participant "Frontend\n(CreateOtPlanPage)" as FE
participant "OtManagementsController" as Ctrl
participant "OtManagementsService" as OTS
participant "OtBalanceService" as OBS
participant "NotificationsService" as NS
database "PostgreSQL" as DB

== Create OT Plan ==
Leader -> FE: Fill form (title, employees,\nstartTime, endTime, etc.)
activate FE

FE -> Ctrl: POST /ot-plans\n(CreateOtPlanDto)
activate Ctrl

Ctrl -> OTS: createOtPlan(userId, dto)
activate OTS

OTS -> DB: Find User (creator) + Department
DB --> OTS: User + Department

alt User not found or not department leader
    OTS --> Ctrl: ForbiddenException
    Ctrl --> FE: 403 Error
    FE --> Leader: "Only department leaders\ncan create OT plans"
else User is department leader

    == Auto-assign Approver ==
    OTS -> DB: Find User with role = ADMIN
    DB --> OTS: Admin user

    alt No Admin user found
        OTS --> Ctrl: BadRequestException
        Ctrl --> FE: 400 Error
        FE --> Leader: "No admin user found\nto assign as approver"
    else Admin user exists
        OTS -> OTS: approverId = admin.id

        == Validate Employees ==
        OTS -> DB: Find selected employees
        DB --> OTS: Employees[]

        alt Some employees not in leader's department
            OTS --> Ctrl: ForbiddenException
            Ctrl --> FE: 403 Error
            FE --> Leader: "Employees do not belong\nto your department"
        else All employees valid

            == Validate Employee Balance (Parallel) ==
        loop for each employee
            OTS -> OBS: validateEmployeeOtBalance(employee, startTime, endTime)
            activate OBS
            OBS -> OBS: Calculate planned duration
            OBS -> DB: SUM ot_balance_transactions\nfor employee
            DB --> OBS: Current balance
            OBS -> OBS: Check if balance sufficient

            alt Insufficient balance
                OBS --> OTS: { valid: false, message }
                OTS --> Ctrl: BadRequestException
                Ctrl --> FE: 400 Error
                FE --> Leader: "Employee X has\ninsufficient OT balance"
            else Balance OK
                OBS --> OTS: { valid: true }
                deactivate OBS
            end
        end

        == Create OT Plan ==
        OTS -> DB: BEGIN TRANSACTION

        OTS -> DB: INSERT ot_plan\n(title, description, departmentId,\ncreatedBy, approverId, status=PENDING)
        DB --> OTS: OtPlan entity

        loop for each employee task
            OTS -> DB: INSERT ot_plan_employee\n(otPlanId, employeeId,\nstartTime, endTime, plannedTask)
            DB --> OTS: OtPlanEmployee entity
        end

        == Enqueue Notification (in transaction) ==
        OTS -> NS: enqueueOtPlanSubmittedNotification(\napprover, context, manager)
        activate NS
        NS -> DB: INSERT email_queue record\n(PENDING status)
        DB --> NS: Email ID
        NS --> OTS: emailIds[]
        deactivate NS

        OTS -> DB: COMMIT

        == Trigger Immediate Send (after commit) ==
        OTS -> NS: triggerImmediateSend(emailIds)
        activate NS
        note right: Fire-and-forget:\nsend email to Approver\n"[Action Required] OT Plan Approval"
        NS --> OTS: (async)
        deactivate NS

        OTS --> Ctrl: OtPlanDetailsDto
        deactivate OTS
        Ctrl --> FE: 201 Created
        deactivate Ctrl
        FE --> Leader: "OT Plan created"
        deactivate FE
    end
end

@enduml

@startuml OT Management - Approve Plan Flow
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title OT Management - Approve Plan Flow

actor Approver
participant "Frontend\n(OtPlanDetailPage)" as FE
participant "OtManagementsController" as Ctrl
participant "OtManagementsService" as OTS
participant "OtBalanceService" as OBS
participant "NotificationsService" as NS
database "PostgreSQL" as DB

== Approve OT Plan ==
Approver -> FE: Click "Approve"
activate FE

FE -> Ctrl: PATCH /ot-plans/:id/approve\n(version)
activate Ctrl

Ctrl -> OTS: approveOtPlan(id, approverId, version)
activate OTS

OTS -> DB: Find OtPlan with employees
DB --> OTS: OtPlan

alt Not Found
    OTS --> Ctrl: NotFoundException
    Ctrl --> FE: 404 Error
    FE --> Approver: "Plan not found"
else Plan Found
    alt Not Approver
        OTS --> Ctrl: ForbiddenException
        Ctrl --> FE: 403 Error
        FE --> Approver: "You are not the approver"
    else Is Approver
        alt Status not PENDING
            OTS --> Ctrl: BadRequestException
            Ctrl --> FE: 400 Error
            FE --> Approver: "Plan cannot be approved"
        else Status is PENDING
            alt Version Conflict
                OTS --> Ctrl: ConflictException
                Ctrl --> FE: 409 Conflict
                FE --> Approver: "Plan was modified.\nPlease refresh."
            else Version OK
                == Update OT Plan ==
                OTS -> DB: BEGIN TRANSACTION

                OTS -> DB: UPDATE ot_plan\nSET status = APPROVED\napprovedAt = now\nversion++
                DB --> OTS: Plan updated

                == Create PENDING_APPROVAL Balance ==
                loop for each employee
                    OTS -> OBS: writeOtPendingApproval(employee, plan)
                    activate OBS
                    note right: Source = OT_PLAN_APPROVED
                    OBS -> DB: INSERT ot_balance_transaction\n(DEBIT, source=OT_PLAN_APPROVED,\nattributedDate=plan.date,\ndays=planned_duration)
                    DB --> OBS: Transaction created
                    deactivate OBS
                end

                == Enqueue Notifications (in transaction) ==
                OTS -> DB: Batch load employee users
                DB --> OTS: Employees[]

                loop for each employee
                    OTS -> NS: enqueueOtAssignmentApprovedNotification(\nemployee, context, manager)
                    activate NS
                    NS -> DB: INSERT email_queue record
                    DB --> NS: Email ID
                    NS --> OTS: emailIds[]
                    deactivate NS
                end

                OTS -> DB: COMMIT

                == Trigger Immediate Send (after commit) ==
                OTS -> NS: triggerImmediateSend(emailIds)
                activate NS
                note right: Fire-and-forget:\nsend emails to all employees
                NS --> OTS: (async)
                deactivate NS

                OTS --> Ctrl: OtPlanDetailsDto
                deactivate OTS
                Ctrl --> FE: 200 OK
                deactivate Ctrl
                FE --> Approver: "Plan approved"
                deactivate FE
            end
        end
    end
end

@enduml

