@startuml Leave Request - Sequence Diagrams
!theme plain
skinparam backgroundColor #FEFEFE
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 250
skinparam sequenceGroupBorderColor #888888

title SkyTimeHub - Leave Request Flow\nSequence Diagrams

' ══════════════════════════════════════════════════════════════
' ACTORS & PARTICIPANTS
' ══════════════════════════════════════════════════════════════
actor "Employee\n(Requester)" as Employee
actor "Approver\n(Manager)" as Approver
actor "HR" as HRUser

participant "Frontend\n(React)" as FE #LightBlue
participant "LeaveRequests\nController" as Ctrl #LightGreen
participant "LeaveRequests\nService" as Svc #LightGreen
participant "LeaveBalance\nService" as BalSvc #LightYellow
participant "Notifications\nService" as NotifSvc #LightCoral
database "PostgreSQL\nDatabase" as DB #LightGray
collections "Email Queue" as EmailQ #Pink

' ══════════════════════════════════════════════════════════════
' 1. SUGGEST END DATE (Pre-fill form)
' ══════════════════════════════════════════════════════════════
== 1. Suggest End Date (Optional - Auto-calculate leave types) ==

Employee -> FE : Select leave type + start date
FE -> Ctrl : POST /leave-requests/suggest-end-date\n{leaveTypeId, startDate, startSession}
Ctrl -> BalSvc : suggestEndDate(\nleaveTypeId, startDate,\nstartSession, options)
BalSvc -> DB : Query leave type policy\n(auto_calculate_end_date, max_days)
DB --> BalSvc : Policy config
BalSvc -> BalSvc : Calculate end date\nbased on policy + calendar
BalSvc --> Ctrl : {suggestedEndDate, suggestedEndSession}
Ctrl --> FE : 200 OK\n{suggestedEndDate, suggestedEndSession}
FE --> Employee : Pre-fill end date on form

' ══════════════════════════════════════════════════════════════
' 2. CREATE LEAVE REQUEST
' ══════════════════════════════════════════════════════════════
== 2. Create Leave Request ==

Employee -> FE : Fill form & Submit
FE -> Ctrl : POST /leave-requests\n{leaveTypeId, startDate, endDate,\nstartSession, endSession, reason,\nworkSolution, ccUserIds}
activate Ctrl

Ctrl -> Svc : createLeaveRequest(userId, dto)
activate Svc

' ── Validations ──
group #F0F0FF Validation Phase
    Svc -> Svc : Validate dates\n(endDate >= startDate)
    Svc -> DB : Find active approver\nfor user
    DB --> Svc : UserApprover record
    alt No approver assigned
        Svc --> Ctrl : 400 Error:\n"No active approver assigned"
        Ctrl --> FE : 400 Bad Request
    end
    Svc -> DB : Fetch requester info
    DB --> Svc : User record
    Svc -> Svc : Validate CC list\n(not self, not approver, not HR)
    Svc -> Svc : Check date overlap\n(slot-based overlap detection)
    Svc -> DB : Query active leave requests\nwith overlapping slots
    DB --> Svc : Conflict check result
    alt Overlap found
        Svc --> Ctrl : 409 Error:\n"Overlaps with existing request"
        Ctrl --> FE : 409 Conflict
    end
end

' ── Pre-flight Balance Validation ──
group #FFFFF0 Pre-flight Balance Check
    Svc -> BalSvc : validateAndPrepare(\nuserId, leaveTypeId,\ndates, sessions)
    activate BalSvc
    BalSvc -> DB : Get leave type + policy
    DB --> BalSvc : LeaveType & Policy
    BalSvc -> BalSvc : Calculate duration\n(business days, half-day steps)
    BalSvc -> DB : Get current balance\n(SUM credits - SUM debits)
    DB --> BalSvc : Current balance
    BalSvc -> BalSvc : Check if balance sufficient\n+ auto-conversion rules
    BalSvc --> Svc : {durationDays, items,\nmonthlyAllocations, warnings}
    deactivate BalSvc

    alt Has warnings & not confirmed
        Svc --> Ctrl : 400 Error:\n{requiresConfirmation: true,\nwarnings: [...]}
        Ctrl --> FE : 400 Requires Confirmation
        FE --> Employee : Show warning dialog\n"Balance insufficient, proceed?"
        Employee -> FE : Confirm
        FE -> Ctrl : POST /leave-requests\n{...dto, confirmDespiteWarning: true}
        note right: Re-submit with\nconfirmation flag
    end
end

' ── Transaction ──
group #F0FFF0 Database Transaction
    Svc -> DB : BEGIN TRANSACTION
    Svc -> DB : INSERT leave_requests\n(status=PENDING)
    DB --> Svc : savedRequest (with ID)

    Svc -> BalSvc : reserveBalanceForSubmit(\nmanager, userId, requestId,\nleaveTypeId, dates, sessions)
    activate BalSvc
    BalSvc -> DB : Advisory lock (prevent race)
    BalSvc -> DB : Re-validate balance\n(inside transaction)
    BalSvc -> DB : INSERT leave_balance_transactions\n(DEBIT RESERVE per month)
    BalSvc --> Svc : {monthlyAllocations, items}
    deactivate BalSvc

    Svc -> DB : INSERT leave_request_items\n(per-month allocation breakdown)
    Svc -> DB : INSERT notification_recipients\n(HR auto + CC user-selected)
    Svc -> DB : COMMIT
end

' ── Notifications ──
group #FFF0F0 Notification Phase (async, outside TX)
    Svc -> NotifSvc : enqueueLeaveRequestNotification(\nrequestId, approverId, context)
    NotifSvc -> EmailQ : Queue email to Approver\n"New leave request from {name}"
    Svc -> NotifSvc : enqueueHRNotification(...)
    NotifSvc -> EmailQ : Queue email to HR users
    Svc -> NotifSvc : enqueueCCNotification(...)
    NotifSvc -> EmailQ : Queue email to CC recipients
end

Svc --> Ctrl : LeaveRequest entity
deactivate Svc
Ctrl --> FE : 201 Created\n{id, status: "pending", ...}
deactivate Ctrl
FE --> Employee : "Leave request submitted!"

' ══════════════════════════════════════════════════════════════
' 3. VIEW LEAVE REQUESTS
' ══════════════════════════════════════════════════════════════
== 3. View Leave Requests ==

group Employee View
    Employee -> FE : Open My Leaves
    FE -> Ctrl : GET /leave-requests
    Ctrl -> Svc : findUserLeaveRequests(userId)
    Svc -> DB : SELECT * FROM leave_requests\nWHERE user_id = ?\nORDER BY created_at DESC
    DB --> Svc : LeaveRequest[]
    Svc --> Ctrl : Transform with ccUserIds
    Ctrl --> FE : 200 OK [...requests]
    FE --> Employee : Display leave list
end

group Management View (HR / Approver)
    Approver -> FE : Open Management
    FE -> Ctrl : GET /leave-requests/management
    Ctrl -> Svc : findRequestsForManagement(user)
    alt user.role === 'hr'
        Svc -> DB : SELECT all requests\n(all statuses)
    else user is Approver
        Svc -> DB : SELECT WHERE approver_id = ?\n(all statuses)
    end
    DB --> Svc : LeaveRequest[]
    Svc --> Ctrl : results
    Ctrl --> FE : 200 OK [...requests]
    FE --> Approver : Display management list
end

' ══════════════════════════════════════════════════════════════
' 4. UPDATE LEAVE REQUEST
' ══════════════════════════════════════════════════════════════
== 4. Update Leave Request (Requester only, PENDING status) ==

Employee -> FE : Edit pending request
FE -> Ctrl : PUT /leave-requests/:id\n{leaveTypeId, dates, sessions,\nreason, ccUserIds, version}
activate Ctrl

Ctrl -> Svc : updateLeaveRequest(id, userId, dto)
activate Svc

group #F0F0FF Validation
    Svc -> DB : Find request (WHERE id & userId)
    DB --> Svc : LeaveRequest
    alt Not found or not owner
        Svc --> Ctrl : 404 Not Found
    end
    alt Status !== PENDING
        Svc --> Ctrl : 400 "Only pending can be updated"
    end
    Svc -> Svc : Validate CC + overlap + balance\n(same as create flow)
end

group #F0FFF0 Transaction (Release → Re-reserve)
    Svc -> DB : BEGIN TRANSACTION

    Svc -> BalSvc : releaseReserveForRejection(\nuserId, requestId, manager)
    BalSvc -> DB : INSERT CREDIT RELEASE\n(undo old RESERVE debits)

    Svc -> DB : UPDATE leave_requests\n(new dates, reason, etc.)

    Svc -> DB : DELETE old leave_request_items

    Svc -> BalSvc : reserveBalanceForSubmit(\n...new params, excludeRequestId)
    BalSvc -> DB : INSERT new DEBIT RESERVE\n(per month)

    Svc -> DB : INSERT new leave_request_items

    Svc -> DB : UPDATE CC recipients\n(delete old + insert new)

    Svc -> DB : COMMIT
end

Svc -> NotifSvc : enqueueLeaveRequestUpdatedNotification(...)
NotifSvc -> EmailQ : Queue "Request updated" emails

Svc --> Ctrl : Updated LeaveRequest
deactivate Svc
Ctrl --> FE : 200 OK {updated request}
deactivate Ctrl
FE --> Employee : "Request updated!"

' ══════════════════════════════════════════════════════════════
' 5. APPROVE LEAVE REQUEST
' ══════════════════════════════════════════════════════════════
== 5. Approve Leave Request (Approver only) ==

Approver -> FE : Click "Approve"
FE -> Ctrl : PATCH /leave-requests/:id/approve\n{version}
activate Ctrl

Ctrl -> Svc : approveLeaveRequest(id, approverId, version)
activate Svc

group #F0F0FF Authorization & Validation
    Svc -> DB : Find request with relations
    DB --> Svc : LeaveRequest
    Svc -> Svc : Verify approverId matches
    Svc -> Svc : Verify status === PENDING
    Svc -> Svc : Optimistic lock check\n(request.version === dto.version)
    alt Version mismatch
        Svc --> Ctrl : 409 Conflict:\n"Request modified since last view"
    end
end

group #F0FFF0 Transaction (RESERVE → APPROVAL)
    Svc -> DB : BEGIN TRANSACTION
    Svc -> DB : UPDATE leave_requests\nSET status='approved',\napproved_at=NOW()
    Svc -> BalSvc : convertReserveToApproval(\nuserId, requestId, manager)
    activate BalSvc
    BalSvc -> DB : UPDATE leave_balance_transactions\nSET source_type='APPROVAL'\nWHERE source_type='RESERVE'\nAND source_id=requestId
    BalSvc --> Svc : done
    deactivate BalSvc
    Svc -> DB : COMMIT
end

group #FFF0F0 Notifications
    Svc -> DB : Load notification recipients
    Svc -> NotifSvc : enqueueLeaveRequestApprovedNotification(...)
    NotifSvc -> EmailQ : Queue "Approved" to Requester
    NotifSvc -> EmailQ : Queue "Approved" to HR + CC
end

Svc --> Ctrl : Updated LeaveRequest
deactivate Svc
Ctrl --> FE : 200 OK {approved request}
deactivate Ctrl
FE --> Approver : "Request approved!"

' ══════════════════════════════════════════════════════════════
' 6. REJECT LEAVE REQUEST
' ══════════════════════════════════════════════════════════════
== 6. Reject Leave Request (Approver only) ==

Approver -> FE : Click "Reject" + enter reason
FE -> Ctrl : PATCH /leave-requests/:id/reject\n{rejectedReason, version}
activate Ctrl

Ctrl -> Svc : rejectLeaveRequest(id, approverId,\nrejectedReason, version)
activate Svc

group #F0F0FF Authorization & Validation
    Svc -> Svc : Verify approver + PENDING status\n+ optimistic lock (same as approve)
end

group #F0FFF0 Transaction (Release RESERVE)
    Svc -> DB : BEGIN TRANSACTION
    Svc -> DB : UPDATE leave_requests\nSET status='rejected',\nrejected_at=NOW(),\nrejected_reason=?
    Svc -> BalSvc : releaseReserveForRejection(\nuserId, requestId, manager)
    activate BalSvc
    BalSvc -> DB : INSERT leave_balance_transactions\n(CREDIT RELEASE per reserve row)
    note right: Gives back reserved\nquota to employee
    BalSvc --> Svc : done
    deactivate BalSvc
    Svc -> DB : COMMIT
end

group #FFF0F0 Notifications
    Svc -> NotifSvc : enqueueLeaveRequestRejectedNotification(...)
    NotifSvc -> EmailQ : Queue "Rejected" to Requester\n(includes rejection reason)
    NotifSvc -> EmailQ : Queue "Rejected" to HR + CC
end

Svc --> Ctrl : Updated LeaveRequest
deactivate Svc
Ctrl --> FE : 200 OK {rejected request}
deactivate Ctrl
FE --> Approver : "Request rejected!"

' ══════════════════════════════════════════════════════════════
' 7. CANCEL LEAVE REQUEST (by Requester)
' ══════════════════════════════════════════════════════════════
== 7. Cancel Leave Request (Requester only) ==

Employee -> FE : Click "Cancel"
FE -> Ctrl : PATCH /leave-requests/:id/cancel
activate Ctrl

Ctrl -> Svc : cancelLeaveRequest(id, userId)
activate Svc

group #F0F0FF Validation
    Svc -> DB : Find request (with items)
    DB --> Svc : LeaveRequest
    Svc -> Svc : Verify requester owns it
    Svc -> Svc : Status must be\nPENDING or APPROVED
end

group #F0FFF0 Transaction (Conditional refund)
    Svc -> DB : BEGIN TRANSACTION
    Svc -> DB : UPDATE leave_requests\nSET status='cancelled',\ncancelled_at=NOW()
    Svc -> DB : DELETE notification_recipients

    alt Was APPROVED
        Svc -> BalSvc : refundBalanceForCancellation(\nuserId, requestId, items, year, mgr)
        BalSvc -> DB : INSERT CREDIT REFUND\n(reverses APPROVAL debits)
        note right: Full refund of\napproved leave days
    else Was PENDING
        Svc -> BalSvc : releaseReserveForRejection(\nuserId, requestId, manager)
        BalSvc -> DB : INSERT CREDIT RELEASE\n(reverses RESERVE debits)
        note right: Release held\nquota back
    end

    Svc -> DB : COMMIT
end

group #FFF0F0 Notifications
    Svc -> NotifSvc : enqueueLeaveRequestCancelledNotification(...)
    NotifSvc -> EmailQ : Queue "Cancelled" to Approver
    NotifSvc -> EmailQ : Queue "Cancelled" to HR + CC
end

Svc --> Ctrl : Updated LeaveRequest
deactivate Svc
Ctrl --> FE : 200 OK {cancelled request}
deactivate Ctrl
FE --> Employee : "Request cancelled!"

' ══════════════════════════════════════════════════════════════
' 8. BALANCE & REPORTING
' ══════════════════════════════════════════════════════════════
== 8. Balance Summary & Monthly Report ==

group Balance Summary
    Employee -> FE : View balance
    FE -> Ctrl : GET /leave-requests/balance-summary
    Ctrl -> BalSvc : getEmployeeBalanceSummary(\nuserId, month, year)
    BalSvc -> DB : Aggregate credits & debits\nper leave type per period
    DB --> BalSvc : Balance data
    BalSvc --> Ctrl : [{leaveType, credit, debit, remaining}]
    Ctrl --> FE : 200 OK
    FE --> Employee : Show balance cards
end

group Monthly Report
    Employee -> FE : View monthly report
    FE -> Ctrl : GET /leave-requests/monthly-report?year=2026
    Ctrl -> BalSvc : getMonthlyBalanceReport(userId, year)
    BalSvc -> DB : Query monthly accruals,\nusage, refunds per month
    DB --> BalSvc : Monthly breakdown
    BalSvc --> Ctrl : [{month, accrual, usage,\nrefund, cumulative}]
    Ctrl --> FE : 200 OK
    FE --> Employee : Show month-by-month table
end

' ══════════════════════════════════════════════════════════════
' STATE MACHINE LEGEND
' ══════════════════════════════════════════════════════════════
legend right
  |= Status |= Transition |= Balance Action |
  | PENDING | → APPROVED | RESERVE → APPROVAL (in-place) |
  | PENDING | → REJECTED | RESERVE → CREDIT RELEASE |
  | PENDING | → CANCELLED | RESERVE → CREDIT RELEASE |
  | APPROVED | → CANCELLED | APPROVAL → CREDIT REFUND |
endlegend

@enduml
