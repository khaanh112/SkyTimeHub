<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your OT Assignment Approved</title>
</head>
<body style="margin:0;padding:0;background-color:#f0f2f5;font-family:'Segoe UI',Arial,sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f0f2f5;padding:40px 16px;">
    <tr><td align="center">
      <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(15,23,42,0.08);">

        <tr>
          <td style="background:#0f172a;padding:20px 32px;">
            <span style="color:#fff;font-size:22px;font-weight:800;letter-spacing:-0.3px;">Sky<span style="color:#38bdf8;">Time</span>Hub</span>
          </td>
        </tr>
        <tr><td style="background:#10b981;height:4px;padding:0;font-size:0;line-height:0;">&nbsp;</td></tr>

        <tr>
          <td style="padding:36px 32px 32px;">

            <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:20px;">
              <tr>
                <td style="background:#ecfdf5;border-radius:100px;padding:5px 14px;">
                  <span style="color:#10b981;font-size:12px;font-weight:700;letter-spacing:0.3px;">✅ APPROVED</span>
                </td>
              </tr>
            </table>

            <h1 style="margin:0 0 6px;font-size:22px;font-weight:700;color:#0f172a;">Your OT Assignment Approved</h1>
            <p style="margin:0 0 24px;color:#64748b;font-size:14px;">Great news! Your OT assignment has been approved.</p>

            <p style="margin:0 0 8px;color:#374151;font-size:15px;">Dear <strong>{{employeeName}}</strong>,</p>
            <p style="margin:0 0 24px;color:#374151;font-size:15px;">This is an automated notification to inform you that your OT assignment has been successfully approved.</p>

            <p style="margin:0 0 20px;color:#374151;font-size:15px;">Please click the link below to view the full details of your specific assignment:</p>

            <table role="presentation" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="border-radius:8px;background:#10b981;">
                  <a href="{{otAssignmentUrl}}" style="display:inline-block;padding:13px 28px;color:#fff;font-weight:700;font-size:15px;text-decoration:none;">View Assignment Details →</a>
                </td>
              </tr>
            </table>

          </td>
        </tr>

        <tr>
          <td style="background:#f8fafc;border-top:1px solid #e2e8f0;padding:20px 32px;text-align:center;">
            <p style="margin:0 0 4px;color:#94a3b8;font-size:12px;">© 2026 SkyTimeHub. All rights reserved.</p>
            <p style="margin:0;color:#94a3b8;font-size:12px;">This is an automated email, please do not reply.</p>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
